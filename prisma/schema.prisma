generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ClassroomRole {
  OWNER
  TEACHER
  STUDENT
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum AvatarType {
  IMAGE
  GENERATED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  GRADING
  GRADED
  EVALUATED
}

model User {
  id              Int      @id @default(autoincrement())
  name            String
  email           String   @unique
  hashed_password String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  avatar           UserAvatar?
  classroomUsers   ClassroomUser[]
  codingChallenges CodingChallenge[]
  Tag              Tag[]
  submissions      Submission[]
}

model UserAvatar {
  id         Int        @id @default(autoincrement())
  user_id    Int        @unique
  type       AvatarType
  image_key  String?
  color      String?
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Classroom {
  id          Int      @id @default(autoincrement())
  class_code  String   @unique
  name        String
  description String?  @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users       ClassroomUser[]
  assignments Assignment[]
  logo        ClassroomLogo?
}

model ClassroomUser {
  id           Int           @id @default(autoincrement())
  user_id      Int
  classroom_id Int
  role         ClassroomRole
  joined_at    DateTime      @default(now())

  user      User      @relation(fields: [user_id], references: [id])
  classroom Classroom @relation(fields: [classroom_id], references: [id], onDelete: Cascade)

  @@unique([user_id, classroom_id])
}

model ClassroomLogo {
  id           Int        @id @default(autoincrement())
  classroom_id Int        @unique
  type         AvatarType
  image_url    String?
  color        String?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  classroom Classroom @relation(fields: [classroom_id], references: [id], onDelete: Cascade)
}

model Assignment {
  id           Int @id @default(autoincrement())
  classroom_id Int

  title        String
  description  String   @db.Text
  due_at       DateTime
  is_published Boolean  @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  classroom            Classroom             @relation(fields: [classroom_id], references: [id], onDelete: Cascade)
  assignmentChallenges AssignmentChallenge[]
  submissions          Submission[]
}

model Tag {
  id         Int      @id @default(autoincrement())
  user_id    Int
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  codingChallenges CodingChallenge[]
  user             User              @relation(fields: [user_id], references: [id])
}

model CodingChallenge {
  id           Int                 @id @default(autoincrement())
  user_id      Int
  tag_id       Int?
  title        String
  description  String              @db.Text
  starter_code String              @db.Text
  language     String
  difficulty   ChallengeDifficulty @default(MEDIUM)
  created_at   DateTime            @default(now())
  updated_at   DateTime            @updatedAt

  user                 User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tag                  Tag?                  @relation(fields: [tag_id], references: [id])
  test_cases           TestCase[]
  assignmentChallenges AssignmentChallenge[]
}

model TestCase {
  id              Int      @id @default(autoincrement())
  challenge_id    Int
  input           String   @db.Text
  expected_output String   @db.Text
  score           Int
  is_hidden       Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  challenge CodingChallenge  @relation(fields: [challenge_id], references: [id], onDelete: Cascade)
}

model AssignmentChallenge {
  id                    Int                 @id @default(autoincrement())
  assignment_id         Int
  original_challenge_id Int
  title                 String
  description           String              @db.Text
  starter_code          String              @db.Text
  language              String
  difficulty            ChallengeDifficulty
  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt

  assignment            Assignment      @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  originalChallenge     CodingChallenge @relation(fields: [original_challenge_id], references: [id])
  codeSubmissions       CodeSubmission[]
  test_cases            AssignmentTestCase[]

  @@unique([assignment_id, original_challenge_id])
}

model AssignmentTestCase {
  id                      Int      @id @default(autoincrement())
  assignment_challenge_id Int
  input                   String   @db.Text
  expected_output         String   @db.Text
  score                   Int
  is_hidden               Boolean  @default(false)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  testResults TestCaseResult[]
  assignmentChallenge AssignmentChallenge @relation(fields: [assignment_challenge_id], references: [id], onDelete: Cascade)
}

model Submission {
  id            Int              @id @default(autoincrement())
  user_id       Int
  assignment_id Int
  status        SubmissionStatus
  total_score   Int               @default(0)
  submitted_at  DateTime          @default(now())
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt

  user        User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assignment  Assignment       @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  codeSubmissions CodeSubmission[]

  @@unique([user_id, assignment_id])
}

model CodeSubmission {
  id                        Int    @id @default(autoincrement())
  code                      String @db.Text
  assignment_challenge_id   Int
  submission_id             Int

  assignmentChallenge AssignmentChallenge @relation(fields: [assignment_challenge_id], references: [id], onDelete: Cascade)
  submission Submission      @relation(fields: [submission_id], references: [id], onDelete: Cascade)
  testResults TestCaseResult[]
}

model TestCaseResult {
  id                 Int     @id @default(autoincrement())
  code_submission_id Int
  case_id            Int
  passed             Boolean
  actual_output      String  @db.Text

  codeSubmission CodeSubmission     @relation(fields: [code_submission_id], references: [id], onDelete: Cascade)
  testCase      AssignmentTestCase  @relation(fields: [case_id], references: [id], onDelete: Cascade)
}
